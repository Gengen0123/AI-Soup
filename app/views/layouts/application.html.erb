<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "AI-Soup" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="AI-Soup">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <%= link_to "AI-Soup", root_path, class: "site-logo" %>

        <details class="global-menu">
  <summary class="global-menu-button" aria-label="メニュー">︙</summary>

  <div class="global-menu-panel">
    <% if logged_in? %>
      <div class="global-menu-user">
        <%= current_user.name %> さん
      </div>

      <%= link_to "自分の問題", my_soup_questions_path, class: "global-menu-link" %>

      <%= button_to "ログアウト",
          logout_path,
          method: :delete,
          class: "global-menu-button-item" %>
    <% else %>
      <%= button_to "Googleでログイン",
          "/auth/google_oauth2",
          method: :post,
          data: { turbo: false },
          class: "global-menu-button-item" %>
    <% end %>

    <%= yield :global_menu_items %>
  </div>
</details>
      </div>
    </header>

    <% if notice.present? %>
      <div class="flash flash-notice">
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="flash flash-alert">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>