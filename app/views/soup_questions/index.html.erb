<% content_for :title, "AI-Soup" %>

<div class="page index-page">
  <header class="page-header">
    <h1>AI-Soup</h1>
    <p>AIが「はい / いいえ / 関係ない」で回答する、ウミガメのスープ風クイズアプリです。</p>

    <div class="new-question-area">
      <%= link_to "新しい問題を作成", new_soup_question_path, class: "primary-link new-question-link" %>
    </div>
  </header>

  <section class="soup-list">
    <h2>問題一覧</h2>

    <% if @soup_questions.any? %>
      <% @soup_questions.each do |soup_question| %>
        <%= render soup_question %>
      <% end %>
    <% else %>
      <p>まだ問題がありません。</p>
    <% end %>
  </section>
</div>