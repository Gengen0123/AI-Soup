<div class="page">
  <%= render @soup_question %>

  <%= link_to "問題一覧に戻る", soup_questions_path %>

  <section class="question-form">
    <h2>質問する</h2>

    <% if @question.errors.any? %>
      <div class="error-box">
        <p>質問を送信できませんでした。</p>
        <ul>
          <% @question.errors.each do |error| %>
            <% if error.attribute == :body && error.type == :blank %>
              <li>質問内容を入力してください</li>
            <% elsif error.attribute == :body && error.type == :too_long %>
              <li>質問内容は200文字以内で入力してください</li>
            <% else %>
              <li><%= error.full_message %></li>
            <% end %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: [@soup_question, @question]) do |f| %>
      <div>
        <%= f.label :body, "質問内容" %><br>
        <%= f.text_area :body %>
      </div>

      <div>
        <%= f.submit "送信" %>
      </div>
    <% end %>
  </section>

  <section class="question-history">
    <h2>これまでの質問</h2>

    <% @soup_question.questions.each do |q| %>
      <div class="question-card">
        <p><strong>Q:</strong> <%= q.body %></p>
        <p class="answer"><strong>A:</strong> <%= q.answer %></p>
      </div>
    <% end %>
  </section>
</div>