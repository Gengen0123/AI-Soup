<% content_for :title, @soup_question.title %>
<% content_for :global_menu_items do %>
  <div class="global-menu-separator"></div>

  <%= link_to "問題一覧に戻る", soup_questions_path, class: "global-menu-link" %>

  <% unless @attempt.gave_up? || @attempt.solved? %>
    <%= button_to "ギブアップ",
        give_up_soup_question_path(@soup_question),
        method: :post,
        class: "global-menu-button-item danger-menu-button",
        data: { turbo_confirm: "ギブアップすると解説が表示されます。本当にギブアップしますか？" } %>
  <% end %>

  <% if logged_in? && @soup_question.user == current_user %>
    <%= link_to "問題を編集する",
        edit_soup_question_path(@soup_question),
        class: "global-menu-link" %>

    <%= button_to "問題を削除する",
        @soup_question,
        method: :delete,
        class: "global-menu-button-item danger-menu-button",
        data: { turbo_confirm: "本当に削除しますか？" } %>
  <% end %>
<% end %>

<div class="page soup-show-page">
  <section class="soup-main-card">
    <h1 class="soup-title"><%= @soup_question.title %></h1>

    <div class="rating-compact">
      <% if @soup_question.ratings_count > 0 %>
        <div>スッキリ度：<%= star_rating(@soup_question.average_clarity_score) %></div>
        <div>難易度：<%= star_rating(@soup_question.average_difficulty_score) %></div>
      <% else %>
        <div>評価：まだありません</div>
      <% end %>
    </div>

    <div class="soup-body">
      <%= simple_format(@soup_question.body) %>
    </div>
  </section>

  <% if @attempt.gave_up? || @attempt.solved? %>
    <section class="answer-reveal compact-section">
      <h2>解説</h2>

      <div class="question-card">
        <p><strong>正解:</strong> <%= @soup_question.answer %></p>
        <p><strong>解説:</strong> <%= @soup_question.explanation %></p>
      </div>

      <div class="action-row">
        <%= button_to "もう一度挑戦する",
            retry_attempt_soup_question_path(@soup_question),
            method: :post,
            class: "btn btn-primary",
            data: { turbo_confirm: "質問履歴とクリア状態をリセットして、もう一度挑戦しますか？" } %>
      </div>
    </section>
  <% end %>

  <section class="question-form compact-section">
    <h2>質問する</h2>

    <% if @question.errors.any? %>
      <div class="error-box">
        <p>質問を送信できませんでした。</p>

        <ul>
          <% @question.errors.each do |error| %>
            <% if error.attribute == :body && error.type == :blank %>
              <li>質問内容を入力してください</li>
            <% elsif error.attribute == :body && error.type == :too_long %>
              <li>質問内容は200文字以内で入力してください</li>
            <% else %>
              <li><%= error.full_message %></li>
            <% end %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: [@soup_question, @question]) do |f| %>
      <div>
        <%= f.text_area :body, placeholder: "はい or いいえ で回答できる質問を記入し、ヒントになる情報を集めましょう。" %>
      </div>

      <div class="question-action-row">
        <%= f.submit "質問する", class: "btn btn-primary btn-question" %>
        <%= link_to "答える",
            answer_soup_question_path(@soup_question),
            class: "btn btn-secondary" %>
      </div>
    <% end %>
  </section>

  <section class="question-history compact-section">
    <h2>これまでの質問</h2>

    <% if @questions.any? %>
      <% @questions.each do |q| %>
        <div class="question-card">
          <p><strong>Q:</strong> <%= q.body %></p>
          <p class="answer"><strong>A:</strong> <%= q.answer %></p>
        </div>
      <% end %>
    <% else %>
      <p>まだ質問はありません。</p>
    <% end %>
  </section>

  <% if logged_in? && @soup_question.user != current_user %>
    <section class="rating-form compact-section">
      <h2>この問題を評価する</h2>

      <% if @rating.present? %>
        <%= form_with(model: [@soup_question, @rating]) do |f| %>
          <div>
            <%= f.label :clarity_score, "スッキリ度" %>
            <%= f.select :clarity_score,
                options_for_select((1..5).map { |n| ["#{n}", n] }, @rating.clarity_score) %>
          </div>

          <div>
            <%= f.label :difficulty_score, "難易度" %>
            <%= f.select :difficulty_score,
                options_for_select((1..5).map { |n| ["#{n}", n] }, @rating.difficulty_score) %>
          </div>

          <%= f.submit "評価を更新する", class: "btn btn-secondary" %>
        <% end %>
      <% else %>
        <%= form_with(model: [@soup_question, SoupQuestionRating.new]) do |f| %>
          <div>
            <%= f.label :clarity_score, "スッキリ度" %>
            <%= f.select :clarity_score,
                options_for_select((1..5).map { |n| ["#{n}", n] }) %>
          </div>

          <div>
            <%= f.label :difficulty_score, "難易度" %>
            <%= f.select :difficulty_score,
                options_for_select((1..5).map { |n| ["#{n}", n] }) %>
          </div>

          <%= f.submit "評価する", class: "btn btn-secondary" %>
        <% end %>
      <% end %>
    </section>
  <% elsif logged_in? && @soup_question.user == current_user %>
    <section class="rating-form compact-section">
      <p>作問者は自分の問題を評価できません。</p>
    </section>
  <% else %>
    <section class="rating-form compact-section">
      <p>評価するにはGoogleログインが必要です。</p>
    </section>
  <% end %>
</div>